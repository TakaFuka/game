{
  "variables": {
    "rest": 0,
    "needtime": 0,
    "stroke": 1,
    "dice": 1
  },

  "screens": [

    {
      "id": "start01",
      "type": "start",

      "showScreenTime": false,

      "counter": {
        "type": "none"
      },

      "text": "開始します",

      "buttons": [
        {
          "label": "開始",

          "visibleCondition": {
            "type": "immediate"
          },

          "transition": {
            "type": "fixed",
            "target": "rest01"
          }
        }
      ]
    },

    {
      "id": "rest01",
      "type": "rest",

      "showScreenTime": true,

      "counter": {
        "type": "none"
      },

      "text": "マス数を選択してください",

      "buttons": [

        {
          "label": "15",

          "visibleCondition": {
            "type": "immediate"
          },

          "variableChanges": [
            {
              "name": "rest",
              "value": 15
            }
          ],

          "transition": {
            "type": "random",
            "pool": "task"
          }
        },

        {
          "label": "30",

          "visibleCondition": {
            "type": "immediate"
          },

          "variableChanges": [
            {
              "name": "rest",
              "value": 30
            }
          ],

          "transition": {
            "type": "random",
            "pool": "task"
          }
        },

        {
          "label": "50",

          "visibleCondition": {
            "type": "immediate"
          },

          "variableChanges": [
            {
              "name": "rest",
              "value": 50
            }
          ],

          "transition": {
            "type": "random",
            "pool": "task"
          }
        },

        {
          "label": "80",

          "visibleCondition": {
            "type": "immediate"
          },

          "variableChanges": [
            {
              "name": "rest",
              "value": 80
            }
          ],

          "transition": {
            "type": "random",
            "pool": "task"
          }
        },

        {
          "label": "100",

          "visibleCondition": {
            "type": "immediate"
          },

          "variableChanges": [
            {
              "name": "rest",
              "value": 100
            }
          ],

          "transition": {
            "type": "random",
            "pool": "task"
          }
        }
      ]
    
    },

    {
      "id": "task01",
      "type": "task",

      "defaultWeight": 1,

      "showScreenTime": false,

      "variableChanges": [

        {
          "name": "needtime",
          "value": "[15,15,15,15,15,15,15,15,15,30,30,30,30,30,30,30,30,45,45,45,60,60,120,150,180][Math.floor(Math.random()*25)]"
        },

        {
          "name": "stroke",
          "value": "1+Math.random()"
        }

      ],

      "counter": {

        "type": "countup",
        
        "start": "Math.floor(Math.random()*20)",

        "interval": "stroke"

      },

      "text": "{needtime}秒のストローク",

      "buttons": [

        {

          "label": "進む",

          "visibleCondition": {

            "type": "immediate"

          },

          "transition": {

            "type": "random",

            "pool": [
              "rest02",
              "rest03"
            ],

            "weights": {

              "rest02": "screenElapsed-needtime+1",

              "rest03": "needtime-screenElapsed"

            }

          }

        }

      ]

    },

    {
      "id": "task02",
      "type": "task",

      "defaultWeight": 1,

      "showScreenTime": false,

      "variableChanges": [

        {

          "name": "needtime",

          "value": "[15,15,15,15,15,15,15,15,15,30,30,30,30,30,30,30,30,45,45,45,60,60,120,150,180][Math.floor(Math.random()*25)]"

        },

        {

          "name": "stroke",

          "value": "0.6+Math.random()*0.2"

        }

      ],

      "counter": {

        "type": "countup",
        
        "start": "Math.floor(Math.random()*20)",

        "interval": "stroke"

      },

      "text": "{needtime}秒のストローク",

      "buttons": [

        {

          "label": "進む",

          "visibleCondition": {

            "type": "immediate"

          },

          "transition": {

            "type": "random",

            "pool": [
              "rest02",
              "rest03"
            ],

            "weights": {

              "rest02": "screenElapsed-needtime+1",

              "rest03": "needtime-screenElapsed"

            }

          }

        }

      ]

    },

    {
      "id": "task03",
      "type": "task",

      "defaultWeight": 1,

      "showScreenTime": false,

      "variableChanges": [

        {

          "name": "needtime",

          "value": "[15,15,15,15,15,15,15,15,15,30,30,30,30,30,30,30,30,45,45,45,60,60,120,150,180][Math.floor(Math.random()*25)]"

        },

        {

          "name": "stroke",

          "value": "0.2+Math.random()*0.3"

        }

      ],

      "counter": {

        "type": "countup",
        
        "start": "Math.floor(Math.random()*20)",

        "interval": "stroke"

      },

      "text": "{needtime}秒のストローク",

      "buttons": [

        {

          "label": "進む",

          "visibleCondition": {

            "type": "immediate"

          },

          "transition": {

            "type": "random",

            "pool": [
              "rest02",
              "rest03"
            ],

            "weights": {

              "rest02": "screenElapsed-needtime+1",

              "rest03": "needtime-screenElapsed"

            }

          }

        }

      ]

    },

    {
      "id": "rest02",

      "type": "rest",

      "showScreenTime": true,

      "variableChanges": [

        {

          "name": "dice",

          "value": "Math.floor(Math.random()*6)+1+Math.ceil(needtime/30)"

        },

        {

          "name": "rest",

          "value": "rest-dice"

        }

      ],

      "counter": {

        "type": "countdown",

        "start": "Math.ceil(needtime/3)+10",

        "interval": 1

      },

      "text": "成功。{dice}マス進む。残り{rest}マス",

      "buttons": [

        {

          "label": "進む",

          "visibleCondition": {

            "type": "immediate"

          },

          "transition": {

            "type": "random",

            "pool": [

              "task",

              "end"

            ],

            "weights": {
              "task01": "rest",
              "task02": "rest",
              "task03": "rest",

              "end01": "-(rest-1)"

            }

          }

        }

      ],

      "autoTransition": {

        "condition": {

          "type": "value",

          "variable": "counterValue",

          "operator": "<=",

          "value": 0

        },

        "transition": {

          "type": "random",

          "pool": [

            "task",

            "end"

          ],

          "weights": {

            "end01": "-(rest-1)"

          }

        }

      }

    },

    
    {
      "id": "rest03",

      "type": "rest",

      "showScreenTime": true,
      
      "variableChanges": [

        {

          "name": "dice",

          "value": "Math.floor(Math.random()*3)+1+Math.ceil((180-needtime)/60)"

        },

        {

          "name": "rest",

          "value": "rest+dice"

        }

      ],

      "counter": {

        "type": "countdown",

        "start": "Math.ceil(needtime/3)+10",

        "interval": 1

      },

      "text": "失敗。{dice}マス戻る。残り{rest}マス",

      "buttons": [

        {

          "label": "進む",

          "visibleCondition": {

            "type": "immediate"

          },

          "transition": {

            "type": "random",

            "pool": [

              "task"

            ],

            "weights": {

              "end01": "-(rest-1)"

            }

          }

        }

      ],

      "autoTransition": {

        "condition": {

          "type": "value",

          "variable": "counterValue",

          "operator": "<=",

          "value": 0

        },

        "transition": {

          "type": "random",

          "pool": [

            "task"

          ]

        }

      }

    },

    {
      "id": "end01",

      "type": "end",

      "showScreenTime": true,

      "counter": {

        "type": "countup",

        "interval": "0.5/(screenElapsed/60+1)"

      },

      "text": "クリア",

      "buttons": [

        {

          "label": "開始画面へ",

          "visibleCondition": {

            "type": "immediate"

          },

          "transition": {

            "type": "fixed",

            "target": "start01"

          }

        }

      ]

    }

  ]
}